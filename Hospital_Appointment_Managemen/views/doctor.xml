<odoo>
    <record id="doctor_form_view" model="ir.ui.view">
        <field name="name">doctor form view</field>
        <field name="model">hospital.doctor</field>
        <field name="arch" type="xml">
            <form string="Doctor">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="specialization"/>
                        <field name="experience_years"/>
                        <field name="is_available"/>
                        <field name="appointment_ids" widget="One2many_tags"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="doctor_list_view" model="ir.ui.view">
        <field name="name">doctor list view</field>
        <field name="model">hospital.doctor</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="specialization"/>
                <field name="experience_years"/>
                <field name="is_available"/>
            </list>
        </field>
    </record>
    <record id="action_doctor_tag" model="ir.actions.act_window">
        <field name="name">Doctor</field>
        <field name="res_model">hospital.doctor</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="hospital_management_main" name="Hospital Management"/>
    <menuitem id="menu_doctor" name="Doctor"
              action="action_doctor_tag" sequence="10"
              parent="hospital_management_main"/>
</odoo>