<odoo>
    <record id="patient_form_view" model="ir.ui.view">
        <field name="name">patient form view</field>
        <field name="model">hospital.patient</field>
        <field name="arch" type="xml">
            <form string="Patient">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="age"/>
                        <field name="gender" widget="radio"/>
                        <field name="blood_group"/>
                        <field name="appointment_ids"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="patient_list_view" model="ir.ui.view">
        <field name="name">patient list view</field>
        <field name="model">hospital.patient</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="age"/>
                <field name="gender"/>
                <field name="blood_group"/>
            </list>
        </field>
    </record>
    <record id="action_patient_tag" model="ir.actions.act_window">
        <field name="name">Patient</field>
        <field name="res_model">hospital.patient</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_patient" name="Patient"
              action="action_patient_tag" sequence="10"
              parent="hospital_management_main"/>
</odoo>