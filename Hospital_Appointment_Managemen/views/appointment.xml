<odoo>
    <record id="appointment_form_view" model="ir.ui.view">
        <field name="name">appointment form view</field>
        <field name="model">hospital.appointment</field>
        <field name="arch" type="xml">
            <form string="Appointment">
                <sheet>
                    <group>
                        <field name="appointment_date"/>
                        <field name="fees"/>
                        <field name="status" widget="radio"/>
                        <field name="is_paid"/>
                        <field name="patient_id"/>
                        <field name="doctor_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="appointment_list_view" model="ir.ui.view">
        <field name="name">appointment list view</field>
        <field name="model">hospital.appointment</field>
        <field name="arch" type="xml">
            <list>
                <field name="patient_id"/>
                <field name="doctor_id"/>
                <field name="appointment_date"/>
                <field name="fees"/>
                <field name="status"/>
                <field name="is_paid"/>
            </list>
        </field>
    </record>
    <record id="action_appointment_tag" model="ir.actions.act_window">
        <field name="name">Appointment</field>
        <field name="res_model">hospital.appointment</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_appointment"
              name="Appointment"
              action="action_appointment_tag" parent="hospital_management_main"
              sequence="20"/>
</odoo>