<odoo>
    <record id="return_date_wizard" model="ir.ui.view">
        <field name="name">return date wizard </field>
        <field name="model">return.date.wizard</field>
        <field name="arch" type="xml">
            <form string="Update Return Date">
                <group>
                    <field name="return_date"/>
                </group>
                <footer>
                    <button string="Confirm" type="object" name="action_confirm" class="btn-primary"/>
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
