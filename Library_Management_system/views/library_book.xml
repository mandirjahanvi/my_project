<odoo>
    <record id="library_book_form" model="ir.ui.view">
        <field name="name">library book form</field>
        <field name="model">library.book</field>
        <field name="arch" type="xml">
            <form string="Book">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="author"/>
                        <field name="available_qty"/>
                        <field name="is_available"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="library_book_list" model="ir.ui.view">
        <field name="name">library book list</field>
        <field name="model">library.book</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="author"/>
                <field name="available_qty"/>
                <field name="is_available"/>
            </list>
        </field>
    </record>
    <record id="action_library_book" model="ir.actions.act_window">
        <field name="name">Books</field>
        <field name="res_model">library.book</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="library_management_main" name="Library Management"/>
    <menuitem id="menu_book" name="Books"
              action="action_library_book" sequence="10"
              parent="library_management_main"/>
</odoo>