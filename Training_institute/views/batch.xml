<odoo>
    <record id="Batch_form_view" model="ir.ui.view">
        <field name="name">Batch Form View</field>
        <field name="model">training.batch</field>
        <field name="arch" type="xml">
            <form string="Batch Form">
                <sheet>
                    <group>
                        <field name="course_id"/>
                        <field name="name"/>
                        <field name="start_date"/>
                        <field name="end_date"/>
                        <field name="capacity"/>
                        <field name="student_ids" widget="One2many_tags"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="batch_list_view" model="ir.ui.view">
        <field name="name">Batch list View</field>
        <field name="model">training.batch</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="course_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="capacity"/>
            </list>
        </field>
    </record>

    <record id="action_batch_tag" model="ir.actions.act_window">
        <field name="name">Batches</field>
        <field name="res_model">training.batch</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_batch" name="Batches"
              action="action_batch_tag"
              parent="training_management_main"/>
</odoo>