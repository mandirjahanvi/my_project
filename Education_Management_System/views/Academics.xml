<odoo>
<!--class form-->
    <record id="view_academic_class_form" model="ir.ui.view">
        <field name="name">view academic class form</field>
        <field name="model">education.class</field>
        <field name="arch" type="xml">
            <form string="Class">
                  <sheet>
                      <div class="oe_title"><h1><field name="class_Name" placeholder="Enter class"/></h1></div>
                      <group>
                          <group>
                            <field name="code"/>
                            <field name="class_Teacher" widget="Many2one_tag"/>
                            <field name="section" widget="radio"/>
                            <field name="capacity"/>
                        </group>
                        <group>
                            <field name="active"/>
                            <field name="subject_id" widget="Many2one_tag"/>
                            <field name="academic_year" widget="Many2one_tag"/>
                            <field name="description"/>
                        </group>
                      </group>
                  </sheet>
            </form>
        </field>
    </record>

<!--Subject form-->
    <record id="view_subject_form" model="ir.ui.view">
        <field name="name">view Subject form</field>
        <field name="model">education.subject</field>
        <field name="arch" type="xml">
           <form string="Timetable">
                  <sheet>
                     <group>
                        <field name="name"/>
                         <field name="code" />
                         <field name="class_id" widget="Many2one_tag"/>
                         <field name="teacher_id" widget="Many2one_tag"/>
                    </group>
                  </sheet>
           </form>
        </field>
    </record>
<!--class list-->
    <record id="view_academic_class_list" model="ir.ui.view">
        <field name="name">view academic class list</field>
        <field name="model">education.class</field>
        <field name="arch" type="xml">
            <list>
                <field name="class_Name"/>
                <field name="class_Teacher"/>
                <field name="academic_year"/>
                <field name="section"/>
                <field name="active"/>
                <field name="subject_id"/>
            </list>
        </field>
    </record>
<!--year list view-->
    <record id="view_academic_year_list" model="ir.ui.view">
        <field name="name">view academic Year list</field>
        <field name="model">edu.year</field>
        <field name="arch" type="xml">
            <list string="Year" editable="bottom">
                <field name="name"/>
            </list>
        </field>
    </record>
<!--Timetable list-->
    <record id="view_timetable_calendar" model="ir.ui.view">
        <field name="name">timetable view</field>
        <field name="model">edu.timetable</field>
        <field name="arch" type="xml">
            <calendar string="Timetable"
                      date_start="start_time"
                      date_stop="end_time"
                      color="teacher_id">
                <field name="subject_id"/>
                <field name="teacher_id"/>
            </calendar>
        </field>
    </record>
<!---subject list-->
     <record id="view_timetable_list" model="ir.ui.view">
        <field name="name">view timetable list</field>
        <field name="model">education.subject</field>
        <field name="arch" type="xml">
            <list>
                    <field name="name"/>
                    <field name="code"/>
                    <field name="class_id"/>
                    <field name="teacher_id"/>
            </list>
        </field>
     </record>
<!--class action-->
        <record id="action_classes" model="ir.actions.act_window">
        <field name="name">Classes</field>
        <field name="res_model">education.class</field>
        <field name="view_mode">list,form</field>
    </record>
<!--year action-->
    <record id="action_academic_year" model="ir.actions.act_window">
        <field name="name">Academic Year</field>
        <field name="res_model">edu.year</field>
        <field name="view_mode">list,form</field>
    </record>
<!--Timetable action-->
    <record id="action_education_timetable" model="ir.actions.act_window">
        <field name="name">Timetable</field>
        <field name="res_model">edu.timetable</field>
        <field name="view_mode">calendar</field>
    </record>
<!--subject action-->
    <record id="action_education_subject" model="ir.actions.act_window">
        <field name="name">Subject</field>
        <field name="res_model">education.subject</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>









