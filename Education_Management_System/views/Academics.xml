<odoo>
    <record id="academic_course_form" model="ir.ui.view">
        <field name="name">academic.course.form</field>
        <field name="model">education.course</field>
        <field name="arch" type="xml">
            <form string="Course">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="duration"/>
                        <field name="total_semester"/>
                    </group>
                    <notebook>
                        <page string="Semesters">
                            <div  style="display:flex; flex-wrap:wrap; gap:10px; margin-bottom:10px;">
                                <button name="action_open_semester"
                                        type="object"
                                        string="Semester 1"
                                        class="btn btn-primary"
                                        context="{'semester_index': 0}"/>
                                <button name="action_open_semester"
                                        type="object"
                                        string="Semester 2"
                                        class="btn btn-primary"
                                        context="{'semester_index': 1}"/>
                                <button name="action_open_semester"
                                        type="object"
                                        string="Semester 3"
                                        class="btn btn-primary"
                                        context="{'semester_index': 2}"/>
                                <button name="action_open_semester"
                                        type="object"
                                        string="Semester 4"
                                        class="btn btn-primary"
                                        context="{'semester_index': 3}"/>
                                <button name="action_open_semester"
                                        type="object"
                                        string="Semester 5"
                                        class="btn btn-primary"
                                        context="{'semester_index': 4}"/>
                                <button name="action_open_semester"
                                        type="object"
                                        string="Semester 6"
                                        class="btn btn-primary"
                                        context="{'semester_index': 5}"/>
                            </div>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ================= COURSE LIST ================= -->

    <record id="view_course_list" model="ir.ui.view">
        <field name="name">education.course.list</field>
        <field name="model">education.course</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="duration"/>
                <field name="total_semester"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- ================= SEMESTER FORM ================= -->

    <record id="view_semester_form" model="ir.ui.view">
        <field name="name">education.semester.form</field>
        <field name="model">education.semester</field>
        <field name="arch" type="xml">
            <form string="Semester">
                <sheet>
                    <h2 style="text-align:center;"><field name="name"/></h2>
                    <group>
                        <field name="course_id"/>
                        <field name="syllabus_pdf" filename="syllabus_filename"/>
                        <field name="syllabus_filename" invisible="1"/>
                        <field name="sequence" invisible="1"/>
                    </group>
                    <!-- SUBJECT KANBAN -->
                    <group string="Subjects">
                        <field name="subject_id">
                            <kanban>
                                <field name="name"/>
                                <field name="subject_code"/>
                                <templates>
                                    <t t-name="kanban-box">
                                        <div class="oe_kanban_card"
                                             style="padding:15px; text-align:center; border-radius:10px;">
                                            <strong><field name="subject_code"/></strong><br/>
                                            <span><field name="name"/></span>
                                        </div>
                                    </t>
                                </templates>
                            </kanban>
                        </field>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ================= SEMESTER KANBAN ================= -->

    <record id="view_semester_kanban" model="ir.ui.view">
        <field name="name">education.semester.kanban</field>
        <field name="model">education.semester</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="name"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <strong><field name="name"/></strong>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ================= SEMESTER LIST ================= -->

    <record id="view_semester_list" model="ir.ui.view">
        <field name="name">education.semester.list</field>
        <field name="model">education.semester</field>
        <field name="arch" type="xml">
            <list default_order="sequence">
                <field name="name"/>
                <field name="course_id"/>
            </list>
        </field>
    </record>

    <!-- ================= SUBJECT VIEWS ================= -->

    <record id="view_subject_kanban" model="ir.ui.view">
        <field name="name">education.subject.kanban</field>
        <field name="model">education.subject</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="name"/>
                <field name="subject_code"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <strong><field name="name"/></strong><br/>
                            <span><field name="subject_code"/></span>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_subject_list" model="ir.ui.view">
        <field name="name">education.subject.list</field>
        <field name="model">education.subject</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="subject_code"/>
                <field name="semester_id"/>
            </list>
        </field>
    </record>
    <record id="action_course" model="ir.actions.act_window">
        <field name="name">Courses</field>
        <field name="res_model">education.course</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>