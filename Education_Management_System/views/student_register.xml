<odoo>
    <!-- Form View -->
    <record id="view_student_register_form" model="ir.ui.view">
        <field name="name">student register form</field>
        <field name="model">student.register</field>
        <field name="arch" type="xml">
            <form string="Student Registration">
                <sheet>
                    <div class="oe_right">
                        <field name="photo" widget="image"
                               class="oe_avatar"
                               options="{'size': [150, 150]}"/>
                    </div>
                    <group>
                        <group>
                            <field name="first_name"/>
                            <field name="admission_no"/>
                            <field name="dob"/>
                            <field name="gender" widget="radio"/>
                        </group>
                        <group>
                            <field name="last_name"/>
                            <field name="phone"/>
                            <field name="email"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Address Details">
                            <group>
                                <field name="address" placeholder="Street"/>
                            <group>
                            <field name="city" placeholder="City" nolabel="1"/>
                            <field name="zipcode" placeholder="Zipcode" nolabel="1"/>
                            <field name="state_id" placeholder="State" nolabel="1"/>
                            <field name="country_id" placeholder="Country" nolabel="1"/>
                        </group>
                        </group>
                        </page>
                       <page string="Documents">
                            <field name="document_ids">
                                <list editable="bottom">
                                    <field name="document_type"/>
                                    <field name="document_file" filename="file_name"/>
                                    <field name="file_name"/>
                                </list>
                                <form>
                                    <group>
                                        <field name="document_type"/>
                                        <field name="document_file" filename="file_name"/>
                                        <field name="file_name"/>
                                    </group>
                                </form>
                            </field>
                       </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- List View -->
    <record id="view_student_register_list" model="ir.ui.view">
        <field name="name">student register list</field>
        <field name="model">student.register</field>
        <field name="arch" type="xml">
            <list string="Students">
                <field name="first_name"/>
                <field name="last_name"/>
                <field name="admission_no"/>
                <field name="phone"/>
                <field name="email"/>
                <field name="city"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Action -->
    <record id="action_student_register" model="ir.actions.act_window">
        <field name="name">Student Registration</field>
        <field name="res_model">student.register</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>