<odoo>
    <record id="teacher_form_view" model="ir.ui.view">
        <field name="name">teacher form view</field>
        <field name="model">edu.teacher</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1>
                         <field name="name"/>
                        </h1>
                     </div>
                    <div class="oe_right">
                        <field name="photo" widget="image"
                               class="oe_avatar"
                               options="{'size': [150, 150]}"/>
                    </div>
                    <group>
                        <group>
                            <field name="dob"/>
                            <field name="email"/>
                            <field name="phone"/>
                            <field name="gender" widget="radio"/>
                        </group>
                        <group>
                            <field name="experience"/>
                            <field name="joining_date"/>
                            <field name="basic_salary"/>
                            <field name="qualification" widget="radio"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="teacher_list_view" model="ir.ui.view">
        <field name="name">teacher list view</field>
        <field name="model">edu.teacher</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="dob"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="gender"/>
            </list>
        </field>
    </record>

    <record id="view_teacher_kanban" model="ir.ui.view">
    <field name="name">teacher kanban view</field>
    <field name="model">edu.teacher</field>
    <field name="arch" type="xml">
        <kanban>
            <!-- Declare fields here -->
            <field name="name"/>
            <field name="email"/>
            <field name="phone"/>
            <field name="photo"/>

            <templates>
                <t t-name="kanban-box">
                    <div class="oe_kanban_global_click o_kanban_record">
                        <div class="row">
                            <!-- Left Side -->
                            <div class="col-8">
                                <strong>
                                    <field name="name"/>
                                </strong>
                                <div>
                                    <field name="email"/>
                                </div>
                                <div>
                                    <field name="phone"/>
                                </div>
                                <div><field name="qualification"/> </div>
                            </div>
                            <!---right side photo-->
                            <div class="col-4 text-end">
                                <img t-att-src="kanban_image('edu.teacher', 'photo', record.id.value)"
                                     class="rounded"
                                     style="max-height:100px;"/>
                            </div>
                        </div>
                    </div>
                </t>
            </templates>
        </kanban>
    </field>
    </record>
    <record id="action_teacher_tag" model="ir.actions.act_window">
        <field name="name">Teacher</field>
        <field name="res_model">edu.teacher</field>
        <field name="view_mode">kanban,list,form</field>
    </record>

</odoo>