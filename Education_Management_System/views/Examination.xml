<odoo>
<!--Exam Schedule-->
        <record id="Exam_schedule_form" model="ir.ui.view">
        <field name="name">Exam schedule form</field>
        <field name="model">exam.schedule</field>
        <field name="arch" type="xml">
            <form string="Schedule">
                  <sheet>
                      <group>
                          <group>
                              <field name="name"/>
                            <field name="class_id" widget="many2one_tags"/>
                            <field name="subject_id" widget="many2one_tags"/>
                            <field name="teacher_id" widget="many2one_tags"/>
                        </group>
                        <group>
                            <field name="exam_date"/>
                            <field name="start_time" widget="float_time"/>
                            <field name="end_time" widget="float_time"/>
                            <field name="room_number"/>
                        </group>
                      </group>
                  </sheet>
            </form>
        </field>
    </record>
<!--Exam Grade-->
    <record id="Exam_grade_form" model="ir.ui.view">
        <field name="name">Exam Grade Form</field>
        <field name="model">exam.grade</field>
        <field name="arch" type="xml">
            <form string="Grade">
                  <sheet>
                      <group>
                          <group>
                            <field name="name"/>
                            <field name="min_marks"/>
                            <field name="max_marks"/>
                            <field name="grade_point"/>
                            <field name="description"/>
                        </group>
                      </group>
                  </sheet>
            </form>
        </field>
    </record>
<!--Result-->
    <record id="Exam_marks_result" model="ir.ui.view">
        <field name="name">Exam result form</field>
        <field name="model">exam.result</field>
        <field name="arch" type="xml">
            <form string="Result">
                  <sheet>
                      <group>
                          <group>
                            <field name="student_id" widget="many2one_tags"/>
                            <field name="exam_id" widget="many2one_tags"/>
                            <field name="result_status"/>
                             <field name="result_line"/>
                        </group>
                        <group>
                            <field name="total_obtained"/>
                            <field name="total_marks"/>
                            <field name="percentage"/>
                            <field name="grade"/>
                        </group>
                      </group>
                  </sheet>
            </form>
        </field>
    </record>
<!--Report-->
    <record id="Exam_report_form" model="ir.ui.view">
        <field name="name">Exam Report form</field>
        <field name="model">exam.report</field>
        <field name="arch" type="xml">
            <form string="Report">
                  <sheet>
                      <group>
                          <group>
                            <field name="student_id" widget="many2one_tags"/>
                            <field name="exam_id" widget="many2one_tags"/>
                            <field name="class_id" widget="many2one_tags"/>
                            <field name="subject_id" widget="many2one_tags"/>
                        </group>
                        <group>
                            <field name="total_marks"/>
                            <field name="percentage"/>
                            <field name="grade"/>
                            <field name="rank"/>
                            <field name="pdf_file"/>
                        </group>
                      </group>
                  </sheet>
            </form>
        </field>
    </record>
<!--exam schedule list-->
    <record id="Exam_schedule_list" model="ir.ui.view">
        <field name="name">Exam Schedule List</field>
        <field name="model">exam.schedule</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="class_id"/>
                <field name="subject_id"/>
                <field name="exam_date"/>
                <field name="room_number"/>
                <field name="teacher_id"/>
            </list>
        </field>
    </record>
<!--Grade list-->
    <record id="Exam_grade_list" model="ir.ui.view">
        <field name="name">Exam Grade List</field>
        <field name="model">exam.grade</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="min_marks"/>
                <field name="max_marks"/>
                <field name="grade_point"/>
                <field name="description"/>
            </list>
        </field>
    </record>
<!--Result list-->
    <record id="Exam_result_list" model="ir.ui.view">
        <field name="name">Exam Result List</field>
        <field name="model">exam.result</field>
        <field name="arch" type="xml">
            <list>
                <field name="student_id" />
                <field name="exam_id"/>
                <field name="result_status"/>
                <field name="result_line"/>
                <field name="total_obtained"/>
                <field name="total_marks"/>
                <field name="percentage"/>
                <field name="grade"/>
            </list>
        </field>
    </record>
<!--Report list-->
    <record id="Exam_report_list" model="ir.ui.view">
        <field name="name">Exam Report List</field>
        <field name="model">exam.report</field>
        <field name="arch" type="xml">
            <list>
                <field name="student_id"/>
                <field name="exam_id"/>
                <field name="class_id"/>
                <field name="total_marks"/>
                <field name="percentage"/>
                <field name="grade"/>
                <field name="rank"/>
            </list>
        </field>
    </record>

<!--exam schedule action-->
    <record id="action_schedule" model="ir.actions.act_window">
       <field name="name">schedule</field>
        <field name="res_model">exam.schedule</field>
        <field name="view_mode">list,form</field>
    </record>
    <record id="action_grade" model="ir.actions.act_window">
       <field name="name">Grade</field>
        <field name="res_model">exam.grade</field>
        <field name="view_mode">list,form</field>
    </record>
    <record id="action_result" model="ir.actions.act_window">
       <field name="name">result</field>
        <field name="res_model">exam.result</field>
        <field name="view_mode">list,form</field>
    </record>
     <record id="action_report" model="ir.actions.act_window">
       <field name="name">report</field>
        <field name="res_model">exam.report</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>