            </list>
        </field>
    </record>
<!--Result list-->
    <record id="Exam_result_list" model="ir.ui.view">
        <field name="name">Exam Result List</field>
        <field name="model">exam.result</field>
        <field name="arch" type="xml">
            <list>
                <field name="student_id"/>
                <field name="exam_id"/>
                <field name="total_marks"/>
                <field name="percentage"/>
                <field name="grade"/>
                <field name="result_status"/>
            </list>
        </field>
    </record>
<!--Report list-->
    <record id="Exam_result_list" model="ir.ui.view">
        <field name="name">Exam Result List</field>
        <field name="model">exam.report</field>
        <field name="arch" type="xml">
            <list>
                <field name="student_id"/>
                <field name="exam_id"/>
                <field name="class_id"/>
                <field name="total_marks"/>
                <field name="percentage"/>
                <field name="grade"/>
                <field name="rank"/>
                <field name="pdf_file"/>
            </list>
        </field>
    </record>

<!--exam schedule action-->
    <record id="action_schedule" model="ir.actions.act_window">
       <field name="name">schedule</field>
        <field name="res_model">exam.schedule</field>
        <field name="view_mode">list,form</field>
    </record>
    <record id="action_Marks" model="ir.actions.act_window">
       <field name="name">Marks</field>
        <field name="res_model">exam.marks</field>
        <field name="view_mode">list,form</field>
    </record>
    <record id="action_grade" model="ir.actions.act_window">
       <field name="name">Grade</field>
        <field name="res_model">exam.grade</field>
        <field name="view_mode">list,form</field>
    </record>
    <record id="action_result" model="ir.actions.act_window">
       <field name="name">result</field>
        <field name="res_model">exam.result</field>
        <field name="view_mode">list,form</field>
    </record>
     <record id="action_report" model="ir.actions.act_window">
       <field name="name">report</field>
