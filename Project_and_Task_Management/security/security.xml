<odoo>

    <record id="group_Project_User" model="res.groups">
       <field name="name">Project management User</field>
    </record>
    <record id="group_Project_Manager" model="res.groups">
        <field name="name">Project management Manager</field>
        <field name="implied_ids" eval="[(4,ref('group_Project_User'))]"/>
    </record>


    <record id="rule_project_user" model="ir.rule">
        <field name="name">project user</field>
        <field name="model_id" ref="model_my_tasks"/>
        <field name="groups" eval="[(4,ref('Project_and_Task_Management.group_Project_User'))]"/>
        <field name="domain_force">[('assignee_to','in',[user.id])]</field>
    </record>

    <record id="rule_project_manager" model="ir.rule">
        <field name="name">Project manager</field>
         <field name="model_id" ref="model_my_tasks"/>
        <field name="groups" eval="[(4,ref('Project_and_Task_Management.group_Project_Manager'))]"/>
        <field name="domain_force">[('project_member_ids','in',[user.id])]</field>
    </record>

</odoo>
