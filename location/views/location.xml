<odoo>
    <!-- city -->
    <record id="view_city_form" model="ir.ui.view">
        <field name="name">bank city form</field>
        <field name="model">bank.city</field>
        <field name="arch" type="xml">
            <form string="Bank city">
                <sheet>
                    <group>
                        <field name="city_name"/>
                    </group>
                    <notebook>
                        <page string="Bank">
                            <field name="bank_id" widget="many2many_tags"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <record id="view_city_list" model="ir.ui.view">
    <field name="name">bank city list view</field>
    <field name="model">bank.city</field>
    <field name="type">list</field>
    <field name="arch" type="xml">
        <list string="Bank city">
            <field name="city_name"/>
            <field name="bank_id" widget="many2many_tags"/>
        </list>
    </field>
</record>

    <!-- bank -->
    <record id="view_bank_form" model="ir.ui.view">
        <field name="name">bank location form view</field>
        <field name="model">bank.location</field>
        <field name="arch" type="xml">
            <form string="Bank">
                <sheet>
                    <group>
                        <field name="bank_name"/>
                    </group>
                    <notebook>
                        <page string="City">
                            <field name="city_id" widget="many2many_tags"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_bank_list" model="ir.ui.view">
        <field name="name">bank location list view</field>
        <field name="model">bank.location</field>
        <field name="arch" type="xml">
            <list string="Bank location">
                <field name="bank_name"/>
                <field name="city_id" widget="many2many_tags"/>
            </list>
        </field>
    </record>

    <record id="action_bank_location" model="ir.actions.act_window">
        <field name="name">Bank Location</field>
        <field name="res_model">bank.location</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_bank_city" model="ir.actions.act_window">
        <field name="name">City</field>
        <field name="res_model">bank.city</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_bank_location_main" name="Bank Location"/>
    <menuitem id="menu_bank_location"
              name="Bank"
              action="action_bank_location"
              sequence="20"
              parent="menu_bank_location_main"/>
    <menuitem id="menu_bank_city"
              name="City"
              action="action_bank_city"
              sequence="10"
              parent="menu_bank_location_main"/>
</odoo>
